# ─── Digital Public Safety Shield ─── API Keys ───
# Get free API key at: https://console.groq.com (no credit card required)
GROQ_API_KEY=
# Kimi K2.5 is primary; Kimi K2.6 free, GPT-OSS, and Qwen are ordered fallbacks.
# Get free API key at: https://openrouter.ai (no credit card required)
OPENROUTER_API_KEY=

# Production deployments must set a long random value (for example: python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET=
DEBUG=false
DEPLOYMENT_MODE=demo

# Production readiness gates. In DEPLOYMENT_MODE=production, demo graph,
# geospatial, and transcript fixtures are blocked unless real integrations are set
# or ALLOW_DEMO_INTELLIGENCE=true is intentionally enabled for a staged demo.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shield_db
EVIDENCE_STORE_URL=
S3_ENDPOINT_URL=
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EVIDENCE_S3_SSE=AES256
EVIDENCE_S3_KMS_KEY_ID=
EVIDENCE_RETENTION_DAYS=365
NCRB_FEED_URL=
BANK_FEED_URL=
TELECOM_FEED_URL=
STATE_FEED_URL=
NCRB_FEED_TOKEN=
BANK_FEED_TOKEN=
TELECOM_FEED_TOKEN=
STATE_FEED_TOKEN=
FEED_POLLING_ENABLED=false
FEED_POLL_INTERVAL_SECONDS=300
CURRENCY_CERTIFIED_MANIFEST=
CURRENCY_YOLO_MODEL_PATH=
OFFICIAL_REPORTING_API_URL=
OFFICIAL_REPORTING_API_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=digital-public-safety-shield
WHATSAPP_MEDIA_INTEGRATION=false
WHATSAPP_MEDIA_BEARER_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
CHANNEL_WEBHOOK_PROVIDER=shared
TWILIO_WEBHOOK_BASE_URL=
WHATSAPP_MEDIA_ALLOWED_HOSTS=api.twilio.com,media.twiliocdn.com
IVR_PROVIDER_CONFIGURED=false
ALLOW_DEMO_INTELLIGENCE=false
# Required for authorized NCRB/state/bank/telecom/certified-currency feed ingestion endpoints.
SHIELD_INGEST_TOKEN=

# Optional durable background analysis. Existing synchronous APIs work when disabled.
ASYNC_JOBS_ENABLED=false
RABBITMQ_URL=amqp://shield:change-me@localhost:5672/
RABBITMQ_DELIVERY_LIMIT=3
RABBITMQ_PREFETCH=1

# Optional shared rate limits for multi-process/API deployments. Redis never stores analysis payloads.
REDIS_ENABLED=false
REDIS_URL=redis://:change-me@localhost:16379/0
REDIS_MAX_CONNECTIONS=20
LOGIN_RATE_LIMIT=8
LOGIN_RATE_WINDOW_SECONDS=300
ANALYSIS_RATE_LIMIT=30
ANALYSIS_RATE_WINDOW_SECONDS=60

# Optional public-channel webhook gate for WhatsApp/IVR providers.
# If set, providers must send X-Shield-Channel-Token or ?token=...
MULTICHANNEL_WEBHOOK_TOKEN=

# Real-time call intervention and signed external alert outbox.
PII_HASH_SECRET=
REALTIME_ALERT_THRESHOLD=0.65
CITIZEN_ALERT_WEBHOOK_URL=
TELECOM_ALERT_WEBHOOK_URL=
MHA_ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SECRET=

# Optional MCP analyst adapter (use a login token; never commit it).
SHIELD_API_BASE_URL=http://localhost:8000
SHIELD_API_TOKEN=
